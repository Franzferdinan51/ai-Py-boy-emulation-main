# AI Provider Configuration
# Supports: OpenAI, Anthropic, Google, Bailian, Local models, etc.

# Option 1: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Option 2: Anthropic  
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet

# Option 3: Bailian (Alibaba)
# BAILIAN_API_KEY=...
# BAILIAN_MODEL=qwen3.5-plus

# Option 4: Local (LM Studio, Ollama, etc.)
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_MODEL=your-local-model

# Vision model (for screen analysis)
# VISION_MODEL=gpt-4o  # or any vision-capable model

# Server config
BACKEND_PORT=5002
FRONTEND_PORT=5173
