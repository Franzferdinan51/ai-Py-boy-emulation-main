# Bailian Models (PRIMARY)
# Get API key from: https://bailian.console.alibaba.com/

BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_MODEL=qwen3.5-plus
BAILIAN_VISION_MODEL=kimi-k2.5
BAILIAN_MINIMAX_MODEL=minimax-M2.7

# Alternative: OpenAI compatible (if using local models)
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# Server config
BACKEND_PORT=5002
FRONTEND_PORT=5173
